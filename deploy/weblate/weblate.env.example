# Copy to `weblate.env` and fill in the secrets, then `docker compose up -d`.
# Generate each secret with:  openssl rand -base64 36
# `weblate.env` is gitignored — never commit real secrets.

# --- PostgreSQL ------------------------------------------------------------
# POSTGRES_DB is read by the postgres image; POSTGRES_DATABASE by Weblate. Keep them equal.
POSTGRES_USER=weblate
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=weblate
POSTGRES_DATABASE=weblate
POSTGRES_HOST=database
POSTGRES_PORT=5432

# --- Redis -----------------------------------------------------------------
REDIS_HOST=cache
REDIS_PORT=6379

# --- Weblate site ----------------------------------------------------------
# No scheme, just the host. This is where translators reach Weblate (behind your proxy).
WEBLATE_SITE_DOMAIN=translate.nielsbox.cc
WEBLATE_SITE_TITLE=ContactSheet Translations
WEBLATE_ALLOWED_HOSTS=translate.nielsbox.cc
# Served over HTTPS by your reverse proxy → secure cookies + correct absolute URLs.
WEBLATE_ENABLE_HTTPS=1
# REQUIRED behind a TLS-terminating proxy (NPM/nginx/Traefik): trust the forwarded scheme.
# Without this, ENABLE_HTTPS=1 turns on SSL redirect but Weblate never sees the request as
# HTTPS (the proxy forwards plain http), so it 301-loops http↔https. This makes it honour
# the proxy's `X-Forwarded-Proto: https`. The second line logs the real client IP.
WEBLATE_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
WEBLATE_IP_PROXY_HEADER=HTTP_X_FORWARDED_FOR

# --- First admin account (created on first boot) ---------------------------
WEBLATE_ADMIN_LOGIN=niels
WEBLATE_ADMIN_EMAIL=nielsfranke@gmail.com
WEBLATE_ADMIN_PASSWORD=CHANGE_ME_admin_password

# --- Outbound email (optional but recommended) -----------------------------
# Needed for contributor sign-up confirmation, password resets, and notifications.
# Without it you can still operate via the admin account, but new translators can't self-register.
#WEBLATE_EMAIL_HOST=smtp.example.com
#WEBLATE_EMAIL_PORT=587
#WEBLATE_EMAIL_HOST_USER=apikey
#WEBLATE_EMAIL_HOST_PASSWORD=CHANGE_ME_smtp
#WEBLATE_EMAIL_USE_TLS=1
#WEBLATE_DEFAULT_FROM_EMAIL=weblate@nielsbox.cc
#WEBLATE_SERVER_EMAIL=weblate@nielsbox.cc

# --- Registration policy ---------------------------------------------------
# Set to 0 to lock public sign-ups (invite-only). Leave 1 to let translators register themselves
# (requires working email above).
WEBLATE_REGISTRATION_OPEN=1
