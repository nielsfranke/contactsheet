# Port exposed on the host (default: 8765)
PORT=8765

# Force the admin auth cookie to be flagged Secure. Usually unnecessary: the cookie
# is auto-flagged Secure whenever the request arrives over HTTPS (X-Forwarded-Proto,
# set by the reverse proxy). Set this only to require Secure unconditionally.
# COOKIE_SECURE=true

# Number of *trusted* reverse-proxy hops in front of the app. Used to find the real
# client IP (for rate limiting + the activity log) from X-Forwarded-For, which is
# spoofable on its left — only the rightmost TRUSTED_PROXY_HOPS entries are trusted.
# Default 1 = the bundled nginx that ships with this compose stack. Set 2 when an
# extra proxy fronts the stack (e.g. Nginx Proxy Manager -> docker host -> bundled
# nginx); set 0 if the app is exposed directly with no proxy. Getting this wrong is
# safe (it over-counts onto a shared bucket) but too high a value lets a client spoof
# its IP and bypass per-IP rate limits, so match it to your actual proxy chain.
# TRUSTED_PROXY_HOPS=2

# --- Optional: non-interactive first-run setup ---------------------------------
# Leave these unset to create the admin account in the browser setup wizard.
# Only fill them in if you want to skip the wizard. SECRET_KEY is auto-generated
# and persisted to the database when blank (override: openssl rand -hex 32).
# SECRET_KEY=
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# Container image source (used by `docker compose pull` to deploy without building).
# Defaults to the project's public GHCR images; override to pull from elsewhere.
# REGISTRY=ghcr.io/nielsfranke
# TAG=latest

# --- Optional: semantic content search (ML sidecar) ----------------------------
# Find photos by what's visible in them ("car at sunset"). Off unless you opt in.
# Start the stack with the extra profile:  docker compose --profile ml up -d
# and point the backend at the sidecar:
# ML_SERVICE_URL=http://ml:8001
# Sidecar tuning (CPU-only ONNX inference):
# ML_QUANTIZED=1     # INT8 graphs — smaller & faster on CPU (set 0 for full precision)
# ML_THREADS=4       # inference threads; keep below host core count so indexing yields to serving
